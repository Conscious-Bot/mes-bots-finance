# Heimdall — env. Copier en .env et remplir. NE JAMAIS committer .env.
# Sur la box: garder TZ=Europe/Paris (les fenetres cron price_monitor 14-22 en dependent).

# --- LLM (non expose: cle locale, rotation optionnelle) ---
ANTHROPIC_API_KEY=sk-ant-xxx
# --- Telegram (BotFather) ---
TELEGRAM_BOT_TOKEN=000000:xxx
TELEGRAM_CHAT_ID=000000000
# --- Sources donnees (non exposees) ---
FMP_API_KEY=xxx
FRED_API_KEY=xxx
# --- Parametres ---
CAPITAL=10000
PAPER_ONLY=true
MIN_CONVICTION=3
ENV=prod
LOG_LEVEL=INFO
TZ=Europe/Paris
# NB: credentials.json + token.json (OAuth Google) ne sont PAS des env vars.
# Fichiers a la racine du repo, gitignores, transferes par scp (token.json re-minte sur le Mac).
