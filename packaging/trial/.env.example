# PRESAGE trial — clés API. TOUTES optionnelles pour le dashboard-only :
# les prix viennent de yfinance (aucune clé). Sans une clé, le composant
# correspondant se met en veille (fail-closed), il ne casse pas.
#
# Copie ce fichier en `.env` et remplis ce que tu veux activer.

# --- Dashboard-only : rien n'est obligatoire ---

# Scoring LLM des signaux + /chat dashboard (payant, console.anthropic.com).
# Absent → panneaux LLM en "mode veille", track record + prix marchent quand même.
ANTHROPIC_API_KEY=

# Fondamentaux (gratuit, financialmodelingprep.com). Absent → pas d'enrichissement fonda.
FMP_API_KEY=

# Macro (gratuit, fred.stlouisfed.org/docs/api/api_key.html). Absent → panneau macro en veille.
FRED_API_KEY=

# RAG /thesis-similar (gratuit, console.voyageai.com). Absent → skill thesis-similar off.
VOYAGE_API_KEY=

# --- Bot Telegram (étage 2, PAS nécessaire pour le trial dashboard) ---
# Crée un bot via @BotFather, récupère ton chat_id. Absent → pas de bot, dashboard seul.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Obsidian (optionnel, si tu utilises Obsidian + plugin Local REST API) ---
OBSIDIAN_API_URL=
OBSIDIAN_API_KEY=
