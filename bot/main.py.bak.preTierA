               f"  Avg cost was: ${r['avg_cost']:.2f}\n"
               f"  Realized PnL (event): ${r['realized_pnl_event']:+,.2f}\n"
               f"  Realized PnL (total): ${r['realized_pnl_total']:+,.2f}\n"
